# Kopieer dit bestand naar .env.local en vul de waardes in.
# .env.local staat in .gitignore en wordt nooit gecommit.

# ===== Anthropic (Claude API) =====
# Hergebruik bestaande key uit Mainframe/01_projecten/trc-platform/.env of nieuwe key aanmaken op console.anthropic.com
ANTHROPIC_API_KEY=
# Model met PDF-vision support. Gebruik de nieuwste sonnet voor demo.
ANTHROPIC_MODEL=claude-sonnet-4-6

# ===== OpenAI (Whisper spraak-naar-tekst) =====
# Hergebruik bestaande key uit trc-platform/.env of nieuwe op platform.openai.com
OPENAI_API_KEY=

# ===== Supabase =====
# Te vinden in Supabase Studio: Project Settings -> API
# Supabase gebruikt sinds 2025 de namen "publishable" (was anon) en "secret" (was service_role)
SUPABASE_URL=
# publishable key (sb_publishable_...) - veilig voor client-side
SUPABASE_PUBLISHABLE_KEY=
# secret key (sb_secret_...) - ALLEEN server-side, nooit naar client sturen
SUPABASE_SECRET_KEY=

# ===== Resend (opleverrapport mailen) - sessie 2A.6 Blok B =====
# Drie velden. Aanmaken: gratis account op resend.dev -> API Keys -> Create.
# API-key van Resend (begint met re_...). ALLEEN server-side.
RESEND_API_KEY=
# Ontvanger van het opleverrapport. In de demo: JOUW eigen mailadres, en wel HETZELFDE
# adres waarmee je het Resend-account hebt aangemaakt (Resend-testopzet stuurt alleen naar
# je eigen account-mail tot je een eigen verzend-domein verifieert).
RAPPORT_EMAIL=
# Afzender. Laat op de Resend-testafzender staan zolang je geen eigen domein hebt geverifieerd.
# Met geverifieerd domein (kluslus.nl): bv. "Kluslus <planning@kluslus.nl>".
RESEND_FROM=onboarding@resend.dev
# Optioneel. Adres waar ANTWOORDEN op de app-mails binnenkomen (reply-to). Leeg = geen reply-to.
# Tip: gebruik een +tag op je Gmail zodat je er in Gmail op kunt filteren, bv:
RESEND_REPLY_TO=bkmkeukenmontage+kluslus@gmail.com
