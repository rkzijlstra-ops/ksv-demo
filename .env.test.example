# Zijspoor (apart test-Supabase-project). Kopieer naar .env.test en vul in zodra je een test-project
# hebt. Zolang .env.test NIET bestaat, draaien de tests tegen .env.local (de huidige omgeving).
# .env.test is gitignored (valt onder .env*).

# --- Test-Supabase-project (de zijspoor-database) ---
SUPABASE_URL=https://JOUW-TEST-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://JOUW-TEST-PROJECT.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...van_het_test_project
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...van_het_test_project

# --- Test-accounts in het test-project (uids uit Authentication -> Users) ---
E2E_BEHEERDER_UID=uuid-van-test-beheerder
E2E_BEHEERDER_EMAIL=test-beheerder@voorbeeld.nl
E2E_MONTEUR_UID=uuid-van-test-monteur
E2E_MONTEUR_EMAIL=test-monteur@voorbeeld.nl

# --- De test-deploy die naar het test-project wijst (voor de browser/mail-e2e) ---
E2E_APP_URL=https://ksv-demo-test.vercel.app

# --- Mail (mag dezelfde Resend als productie; recipients zijn test-adressen) ---
RESEND_API_KEY=re_...
RESEND_FROM=Keukenstudio Voorschoten <planning@kluslus.nl>
RESEND_REPLY_TO=bkmkeukenmontage+kluslus@gmail.com
RAPPORT_EMAIL=bkmkeukenmontage@gmail.com

# --- Overige (nodig om de app/parser te laten draaien op de test-deploy) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
