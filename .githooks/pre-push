#!/bin/sh
# Deploy-poort: niets gaat naar GitHub (en dus Vercel) als de tests rood zijn.
# Draait de volledige suite (unit + integratie + browser-e2e). In nood bewust
# overslaan met:  git push --no-verify
#
# Let op: dit is een lokale poort (alleen op deze machine, omzeilbaar). Voor een
# server-side poort die niet te omzeilen is, zie de CI-stap in TOESTANDEN.md / README.

echo "[pre-push] Volledige test-suite draaien voor de push (npm run test:all)..."
npm run test:all
status=$?
if [ "$status" -ne 0 ]; then
  echo ""
  echo "[pre-push] GEBLOKKEERD: de tests zijn rood. Fix ze voor je pusht."
  echo "[pre-push] In nood bewust overslaan: git push --no-verify"
  exit 1
fi
echo "[pre-push] Alles groen. Push gaat door."
exit 0
