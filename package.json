{
  "name": "keukenstudio-voorschoten-demo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prepare": "node -e \"try{require('child_process').execSync('git config core.hooksPath .githooks')}catch(e){}\"",
    "dev": "next dev",
    "prebuild": "node scripts/genereer-sw-versie.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:int": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:demo": "playwright test --config playwright.demo.config.ts",
    "screenshots:handleiding": "playwright test --config playwright.handleiding.config.ts",
    "test:mail": "cross-env E2E_MAIL=1 playwright test e2e/mail.spec.ts e2e/mail-opdracht.spec.ts e2e/mail-flows.spec.ts",
    "test:all": "npm test && npm run test:int && npm run test:e2e",
    "migrate:test": "node --env-file=.env.local scripts/migrate.mjs",
    "seed:demo": "node --env-file=.env.local --experimental-strip-types scripts/seed-demo.ts",
    "reset:demo": "node --env-file=.env.local --experimental-strip-types scripts/seed-demo.ts",
    "perf": "node --env-file=.env.local scripts/perf-meting.mjs",
    "setup:test": "node --experimental-strip-types scripts/setup-test-users.ts",
    "check:env": "node --env-file=.env.local --experimental-strip-types scripts/check-env.ts",
    "generate:fake-pdf": "node --experimental-strip-types scripts/generate-fake-pdf.ts",
    "test:sms": "node --env-file=.env.local --experimental-strip-types scripts/test-sms.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "fflate": "^0.8.3",
    "idb": "^8.0.3",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.10.38",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^20.19.41",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.7",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "pg": "^8.21.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
